# ------------------------------------------------------------------
# Email Configuration for Weekly Security Report
# ------------------------------------------------------------------
# SMTP host - Common options:
#   Gmail:    smtp.gmail.com
#   Outlook:  smtp.office365.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false

# The email account that SENDS the report
# For Gmail, you MUST use an "App Password", NOT your real password.
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_USER=your_sending_email@gmail.com
EMAIL_PASS=your_16_char_app_password

# ------------------------------------------------------------------
# Recipients
# ------------------------------------------------------------------
CEO_EMAIL=ceo@yourcompany.com
IT_HEAD_EMAIL=it@yourcompany.com

# ------------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------------
PORT=3001

# CORS - Comma-separated list of allowed origins (leave empty to allow all same-host requests)
# Example: CORS_ORIGIN=http://192.168.1.50:3001,https://yourcompany.com
CORS_ORIGIN=

# ------------------------------------------------------------------
# Device to scan (Ubuntu Server) - optional, filled once
# ------------------------------------------------------------------
SCAN_DEVICE_TYPE=ubuntusrv
SCAN_DEVICE_NAME=Main-Server-01
SCAN_DEVICE_IP=192.168.1.100
SCAN_DEVICE_USER=ubuntu
SCAN_DEVICE_PASS=your_ssh_password_here
